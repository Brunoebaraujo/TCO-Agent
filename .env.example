# =============================================================
# TCO Engine — Variáveis de ambiente
# Copiar para .env e preencher os valores
# NUNCA commitar o arquivo .env no GitHub
# =============================================================

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...          # Obter em console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6        # Modelo padrão

# --- Banco de dados ---
# Railway preenche DATABASE_URL automaticamente em produção
# Para desenvolvimento local, criar um banco PostgreSQL local
DATABASE_URL=postgresql://user:password@localhost:5432/tco_engine

# --- Backend ---
SECRET_KEY=gerar-uma-chave-aleatoria-aqui   # python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=development                      # development | production
CORS_ORIGINS=http://localhost:5173           # URL do frontend (separar por vírgula se houver mais de um)

# --- Frontend (prefixo VITE_ obrigatório para expor ao browser) ---
VITE_API_URL=http://localhost:8000           # URL do backend
VITE_APP_NAME=TCO Engine

# --- Salesforce (Fase 2 — deixar vazio até ter acesso) ---
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_INSTANCE_URL=https://goodpack.my.salesforce.com

# --- Email / Notificações (opcional — Fase 3) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
